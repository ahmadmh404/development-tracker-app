# Database Configuration
# PostgreSQL environment variables for docker-compose

DB_NAME=project-tracker
DB_USER=postgres
DB_PASSWORD=password123
DB_PORT=5432

# Full connection string for Drizzle ORM
# For Docker:
DATABASE_URL=postgresql://postgres:password123@localhost:5432/project-tracker

# For local PostgreSQL installation:
# DATABASE_URL=postgresql://project-tracker-user:password123@localhost:5432/project-tracker

# Next.js configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3001
